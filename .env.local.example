# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/bolajon-uz

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1825d

# Next.js
NEXTAUTH_URL=http://localhost:3007

# App Configuration
NEXT_PUBLIC_APP_NAME=Bolajon.uz
NEXT_PUBLIC_APP_URL=http://localhost:3007
PORT=3007

# Redis Cache (optional - if not set, uses in-memory fallback)
# Get free Redis from https://upstash.com or https://redis.com
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Payme Configuration
# Get these from https://merchant.paycom.uz
PAYME_MERCHANT_ID=your_merchant_id_here
PAYME_SECRET_KEY=your_secret_key_here
PAYME_ENDPOINT=https://checkout.paycom.uz/api

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Cron Job Secret
CRON_SECRET=your-cron-secret-key
