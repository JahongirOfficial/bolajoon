# SMS API sozlamalari
# Eskiz.uz uchun misol

# SMS API URL (Eskiz.uz)
SMS_API_URL=https://notify.eskiz.uz/api/message/sms/send

# SMS API Token (Eskiz.uz dan olinadi)
# Eskiz.uz saytiga kirib, API tokenni oling
SMS_API_TOKEN=your_eskiz_token_here

# SMS Sender ID (Eskiz.uz dan olingan 4 xonali kod)
SMS_SENDER_ID=4546

# Boshqa SMS providerlar uchun:
# - Playmobile.uz
# - SMS.uz
# - va boshqalar
# Ularning API dokumentatsiyasiga qarang
